## §4 — BOUNDARY-EDGE LOCK-INS (P3)

### Go: table-driven edge sweep

```go
// Regression for: ParsePagination accepted page=-1 and returned offset=-LIMIT.
func TestRegression_ParsePagination_edge_inputs(t *testing.T) {
    cases := []struct {
        name        string
        page, size  string
        wantOffset  int
        wantErr     bool
    }{
        {"empty defaults", "", "", 0, false},
        {"zero page rejected", "0", "20", 0, true},
        {"negative page rejected", "-1", "20", 0, true},
        {"page 1", "1", "20", 0, false},
        {"page 2", "2", "20", 20, false},
        {"size over max clamped", "1", "10000", 0, false}, // assert clamping behavior
        {"size = 0 rejected", "1", "0", 0, true},
        {"max int page rejected", strconv.Itoa(math.MaxInt32), "20", 0, true},
    }
    for _, tc := range cases {
        t.Run(tc.name, func(t *testing.T) {
            offset, err := ParsePagination(tc.page, tc.size)
            if tc.wantErr {
                require.Error(t, err)
                return
            }
            require.NoError(t, err)
            require.Equal(t, tc.wantOffset, offset)
        });
    }
}
```

### Web: parametric edge sweep

```ts
// Regression for: formatDuration(NaN) returned "NaNms" in the UI.
import { describe, it, expect } from "vitest";
import { formatDuration } from "./formatDuration";

describe("formatDuration regression — edge inputs", () => {
  it.each([
    { input: 0,         expected: "0ms"  },
    { input: -1,        expected: "0ms"  }, // clamp negative to zero
    { input: NaN,       expected: "—"    },
    { input: Infinity,  expected: "—"    },
    { input: 999,       expected: "999ms" },
    { input: 1000,      expected: "1.0s"  },
    { input: 60_000,    expected: "1.0m"  },
    { input: Number.MAX_SAFE_INTEGER, expected: "—" }, // unrealistic, render dash
  ])("returns $expected for $input", ({ input, expected }) => {
    expect(formatDuration(input)).toBe(expected);
  });
});
```

