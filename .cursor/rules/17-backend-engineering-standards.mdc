## 14. CODE STYLE RULES

```typescript
// ✅ Explicit return types on public functions
async function createCharge(input: CreateChargeInput): Promise<Charge> { }

// ✅ Early returns over nested conditionals
async function processWebhook(event: WebhookEvent) {
  if (!isValidSignature(event)) throw new AuthenticationError(...);
  if (await isDuplicate(event.id)) return; // idempotency
  if (!isSupportedEventType(event.type)) {
    log.debug({ eventType: event.type }, "Unsupported webhook type, skipping");
    return;
  }
  // main logic here
}

// ✅ Avoid magic numbers — use named constants
const MAX_RETRY_ATTEMPTS  = 5;
const CACHE_TTL_SECONDS   = 300;
const CHARGE_TIMEOUT_MS   = 5_000;
const MAX_INVOICE_AMOUNT  = 99_999_99; // cents

// ✅ Prefer immutability
const updatedConfig = { ...config, timeout: 5_000 };

// ✅ Use Result types for expected failures (avoid throw for control flow)
type Result<T, E = AppError> = { ok: true; value: T } | { ok: false; error: E };
```

