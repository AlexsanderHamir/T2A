## 11. STARTUP & SHUTDOWN

```typescript
// Validate config before accepting traffic
async function bootstrap() {
  log.info({ version: process.env.GIT_SHA, env: process.env.NODE_ENV }, "Service starting");

  validateEnv(["DATABASE_URL", "REDIS_URL", "STRIPE_SECRET_KEY"]);
  await db.connect();
  await redis.connect();

  log.info("All dependencies connected — service ready");
  server.listen(port, () => log.info({ port }, "HTTP server listening"));
}

// Graceful shutdown — drain in-flight requests
async function shutdown(signal: string) {
  log.info({ signal }, "Shutdown signal received — draining");

  server.close(async () => {
    await queue.close();       // stop accepting jobs
    await db.end();            // close DB pool
    await redis.quit();        // flush redis buffer
    log.info("Graceful shutdown complete");
    process.exit(0);
  });

  // Force exit if drain takes too long
  setTimeout(() => {
    log.error("Graceful shutdown timed out — forcing exit");
    process.exit(1);
  }, 15_000);
}

process.on("SIGTERM", () => shutdown("SIGTERM"));
process.on("SIGINT",  () => shutdown("SIGINT"));
```

