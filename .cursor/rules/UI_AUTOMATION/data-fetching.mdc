# Data Fetching Patterns

Reference file for the frontend improvement agent. When fixing **P1 — Data Fetching Anti-Patterns**, follow these patterns exactly.

---

## 1. THE THREE-STATE RULE

Every component that fetches data MUST render three explicit UI states. No exceptions.

```tsx
function ResourceList() {
  const { data, isLoading, error } = useFetchResource();

  if (isLoading) return <ResourceListSkeleton />;

  if (error) return (
    <ErrorState
      message="Failed to load resources"
      onRetry={() => refetch()}
    />
  );

  if (!data || data.length === 0) return (
    <EmptyState
      icon={<InboxIcon />}
      title="No resources yet"
      description="Create your first resource to get started."
      action={{ label: "Create resource", onClick: handleCreate }}
    />
  );

  return <FadeIn>{/* render data */}</FadeIn>;
}
```

**Loading state:** Always a skeleton that matches real content dimensions. Never a spinner for content areas. See `skeleton-loading.mdc` for component templates.

**Error state pattern:**
```tsx
interface ErrorStateProps {
  message: string;
  onRetry?: () => void;
  className?: string;
}

function ErrorState({ message, onRetry, className }: ErrorStateProps) {
  return (
    <div
      className={className}
      role="alert"
      style={{
        padding: 'var(--space-6)',
        background: 'var(--color-error-subtle)',
        borderRadius: 'var(--radius-lg)',
        textAlign: 'center',
      }}
    >
      <p style={{
        color: 'var(--color-error)',
        fontSize: 'var(--text-sm)',
        fontWeight: 500,
        marginBottom: onRetry ? 'var(--space-3)' : 0,
      }}>
        {message}
      </p>
      {onRetry && (
        <button
          onClick={onRetry}
          className="btn-secondary"
          style={{ fontSize: 'var(--text-sm)' }}
        >
          Try again
        </button>
      )}
    </div>
  );
}
```

**Empty state pattern:**
```tsx
interface EmptyStateProps {
  icon: React.ReactNode;
  title: string;
  description: string;
  action?: { label: string; onClick: () => void };
}

function EmptyState({ icon, title, description, action }: EmptyStateProps) {
  return (
    <div style={{
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      justifyContent: 'center',
      padding: 'var(--space-12) var(--space-6)',
      textAlign: 'center',
    }}>
      <div style={{
        color: 'var(--color-text-tertiary)',
        marginBottom: 'var(--space-4)',
        fontSize: '48px',
      }}>
        {icon}
      </div>
      <h3 style={{
        fontSize: 'var(--text-lg)',
        fontWeight: 600,
        color: 'var(--color-text-primary)',
        marginBottom: 'var(--space-2)',
      }}>
        {title}
      </h3>
      <p style={{
        fontSize: 'var(--text-sm)',
        color: 'var(--color-text-secondary)',
        maxWidth: '280px',
        marginBottom: action ? 'var(--space-5)' : 0,
      }}>
        {description}
      </p>
      {action && (
        <button onClick={action.onClick} className="btn-primary">
          {action.label}
        </button>
      )}
    </div>
  );
}
```

