## 2. FETCH WITH ABORT CONTROLLER

Every `useEffect` that fetches data MUST clean up with an AbortController. This prevents state updates on unmounted components and cancels in-flight requests on navigation.

**Raw fetch pattern (when no data layer exists):**
```tsx
function useResource(id: string) {
  const [data, setData] = useState<Resource | null>(null);
  const [error, setError] = useState<Error | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const controller = new AbortController();

    async function fetchData() {
      setIsLoading(true);
      setError(null);

      try {
        const response = await fetch(`/api/resources/${id}`, {
          signal: controller.signal,
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }

        const result = await response.json();
        setData(result);
      } catch (err) {
        if (err instanceof DOMException && err.name === 'AbortError') return;
        setError(err instanceof Error ? err : new Error('Unknown error'));
      } finally {
        if (!controller.signal.aborted) {
          setIsLoading(false);
        }
      }
    }

    fetchData();
    return () => controller.abort();
  }, [id]);

  const refetch = useCallback(() => {
    setData(null);
    setIsLoading(true);
    // re-trigger by changing a dep — or inline the fetch
  }, []);

  return { data, error, isLoading, refetch };
}
```

**Critical details:**
- Always check `controller.signal.aborted` before setting state in `finally`
- Always catch and ignore `AbortError` — it's not a real error
- Always expose a `refetch` function for error state retry buttons
- Never `setIsLoading(false)` after an abort — the component is unmounting

