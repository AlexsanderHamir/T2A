## 3. REACT QUERY / TANSTACK QUERY PATTERN

If the project uses React Query (or should — see migration criteria below), follow this pattern:

```tsx
import { useQuery } from '@tanstack/react-query';

function useResource(id: string) {
  return useQuery({
    queryKey: ['resource', id],
    queryFn: async ({ signal }) => {
      const response = await fetch(`/api/resources/${id}`, { signal });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return response.json() as Promise<Resource>;
    },
    staleTime: 5 * 60 * 1000,      // 5 min — don't refetch if fresh
    retry: 2,                        // retry failed requests twice
    retryDelay: (attempt) => Math.min(1000 * 2 ** attempt, 10000),
  });
}
```

**In the component:**
```tsx
function ResourceDetail({ id }: { id: string }) {
  const { data, isLoading, error, refetch } = useResource(id);

  if (isLoading) return <ResourceDetailSkeleton />;
  if (error) return <ErrorState message="Failed to load resource" onRetry={() => refetch()} />;
  if (!data) return <EmptyState icon={<FileIcon />} title="Resource not found" description="This resource may have been deleted." />;

  return <FadeIn>{/* render */}</FadeIn>;
}
```

**React Query benefits over raw fetch:**
- Automatic abort on unmount (via `signal` in `queryFn`)
- Deduplication — same `queryKey` across components = one request
- Stale-while-revalidate — shows cached data instantly, refreshes in background
- Built-in retry with exponential backoff
- Devtools for debugging

