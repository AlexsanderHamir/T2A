## 4. CROSSFADE: SKELETON → REAL CONTENT

Never hard-swap skeleton for real content. Always crossfade.

**Pattern — wrapper component:**
```tsx
import { useState, useEffect, type ReactNode } from 'react';

interface CrossfadeProps {
  isLoading: boolean;
  skeleton: ReactNode;
  children: ReactNode;
  minLoadingMs?: number;
}

function Crossfade({ isLoading, skeleton, children, minLoadingMs = 300 }: CrossfadeProps) {
  const [showSkeleton, setShowSkeleton] = useState(isLoading);
  const [hasMinElapsed, setHasMinElapsed] = useState(false);

  // Enforce minimum loading duration to prevent flash
  useEffect(() => {
    if (isLoading) {
      setShowSkeleton(true);
      setHasMinElapsed(false);
      const timer = setTimeout(() => setHasMinElapsed(true), minLoadingMs);
      return () => clearTimeout(timer);
    }
  }, [isLoading, minLoadingMs]);

  // Transition out skeleton only after both: data ready AND min elapsed
  useEffect(() => {
    if (!isLoading && hasMinElapsed) {
      setShowSkeleton(false);
    }
  }, [isLoading, hasMinElapsed]);

  return (
    <div style={{ position: 'relative' }}>
      {/* Skeleton layer */}
      <div
        aria-hidden="true"
        style={{
          opacity: showSkeleton ? 1 : 0,
          transition: 'opacity 200ms var(--ease-in)',
          position: showSkeleton ? 'relative' : 'absolute',
          inset: showSkeleton ? undefined : 0,
          pointerEvents: showSkeleton ? 'auto' : 'none',
        }}
      >
        {skeleton}
      </div>

      {/* Content layer */}
      {!showSkeleton && (
        <div
          style={{
            opacity: 1,
            animation: 'fadeSlideIn 200ms var(--ease-out) forwards',
          }}
        >
          {children}
        </div>
      )}
    </div>
  );
}
```

**Required keyframe (add globally):**
```css
@keyframes fadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
```

**Usage:**
```tsx
function UserList() {
  const { data, isLoading, error } = useUsers();

  if (error) return <ErrorState message="Failed to load users" onRetry={refetch} />;

  return (
    <Crossfade
      isLoading={isLoading}
      skeleton={
        <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--space-3)' }}>
          {Array.from({ length: 5 }).map((_, i) => <AvatarRowSkeleton key={i} />)}
        </div>
      }
    >
      {data?.length === 0 ? (
        <EmptyState icon={<UsersIcon />} title="No users yet" description="Invite your team to get started." />
      ) : (
        <ul>
          {data?.map(user => <UserRow key={user.id} user={user} />)}
        </ul>
      )}
    </Crossfade>
  );
}
```

