## 3. SKELETON RECIPES BY CONTENT TYPE

### Text block
```tsx
function TextSkeleton({ lines = 3 }: { lines?: number }) {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--space-2)' }}>
      {Array.from({ length: lines }).map((_, i) => (
        <Skeleton
          key={i}
          height="var(--text-base)"
          width={i === lines - 1 ? '60%' : '100%'}
        />
      ))}
    </div>
  );
}
```
Last line is shorter (60%) to mimic natural text ending.

### Card
```tsx
function CardSkeleton() {
  return (
    <div
      aria-hidden="true"
      style={{
        padding: 'var(--space-6)',
        borderRadius: 'var(--radius-lg)',
        border: '1px solid var(--color-border)',
      }}
    >
      <Skeleton height="var(--text-lg)" width="40%" style={{ marginBottom: 'var(--space-3)' }} />
      <Skeleton height="var(--text-sm)" width="80%" style={{ marginBottom: 'var(--space-2)' }} />
      <Skeleton height="var(--text-sm)" width="65%" />
    </div>
  );
}
```

### Card grid
```tsx
function CardGridSkeleton({ count = 6 }: { count?: number }) {
  return (
    <div style={{
      display: 'grid',
      gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))',
      gap: 'var(--space-5)',
    }}>
      {Array.from({ length: count }).map((_, i) => (
        <CardSkeleton key={i} />
      ))}
    </div>
  );
}
```

### Table row
```tsx
function TableRowSkeleton({ columns = 4 }: { columns?: number }) {
  return (
    <tr aria-hidden="true">
      {Array.from({ length: columns }).map((_, i) => (
        <td key={i} style={{ padding: 'var(--space-3) var(--space-4)' }}>
          <Skeleton height="var(--text-sm)" width={i === 0 ? '70%' : '50%'} />
        </td>
      ))}
    </tr>
  );
}

function TableSkeleton({ rows = 5, columns = 4 }: { rows?: number; columns?: number }) {
  return (
    <table style={{ width: '100%' }} aria-hidden="true">
      <thead>
        <tr>
          {Array.from({ length: columns }).map((_, i) => (
            <th key={i} style={{ padding: 'var(--space-3) var(--space-4)', textAlign: 'left' }}>
              <Skeleton height="var(--text-xs)" width="60%" />
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {Array.from({ length: rows }).map((_, i) => (
          <TableRowSkeleton key={i} columns={columns} />
        ))}
      </tbody>
    </table>
  );
}
```

### Avatar + text (user row, comment, notification)
```tsx
function AvatarRowSkeleton() {
  return (
    <div style={{
      display: 'flex',
      alignItems: 'center',
      gap: 'var(--space-3)',
    }}>
      <Skeleton width="40px" height="40px" borderRadius="var(--radius-full)" />
      <div style={{ flex: 1, display: 'flex', flexDirection: 'column', gap: 'var(--space-1)' }}>
        <Skeleton height="var(--text-sm)" width="30%" />
        <Skeleton height="var(--text-xs)" width="55%" />
      </div>
    </div>
  );
}
```

### Metric / stat card
```tsx
function MetricSkeleton() {
  return (
    <div style={{
      padding: 'var(--space-6)',
      borderRadius: 'var(--radius-lg)',
      border: '1px solid var(--color-border)',
    }}>
      <Skeleton height="var(--text-xs)" width="40%" style={{ marginBottom: 'var(--space-3)' }} />
      <Skeleton height="2rem" width="60%" style={{ marginBottom: 'var(--space-2)' }} />
      <Skeleton height="var(--text-xs)" width="30%" />
    </div>
  );
}
```

### Image / media placeholder
```tsx
function ImageSkeleton({ aspectRatio = '16/9' }: { aspectRatio?: string }) {
  return (
    <Skeleton
      width="100%"
      height="auto"
      borderRadius="var(--radius-md)"
      style={{ aspectRatio }}
    />
  );
}
```

### Full page shell
```tsx
function PageSkeleton() {
  return (
    <div style={{ padding: 'var(--space-8)' }} aria-hidden="true">
      {/* Page title */}
      <Skeleton height="var(--text-2xl)" width="35%" style={{ marginBottom: 'var(--space-2)' }} />
      <Skeleton height="var(--text-sm)" width="50%" style={{ marginBottom: 'var(--space-8)' }} />

      {/* Metrics row */}
      <div style={{
        display: 'grid',
        gridTemplateColumns: 'repeat(auto-fill, minmax(200px, 1fr))',
        gap: 'var(--space-5)',
        marginBottom: 'var(--space-8)',
      }}>
        <MetricSkeleton />
        <MetricSkeleton />
        <MetricSkeleton />
      </div>

      {/* Content area */}
      <TableSkeleton rows={5} columns={4} />
    </div>
  );
}
```

