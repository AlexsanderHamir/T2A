## 4. STAGGERED LIST ANIMATION

For lists of items that appear together (search results, card grids, table rows loaded at once). Each child enters with an incremental delay.

```tsx
interface StaggeredListProps {
  children: ReactNode[];
  staggerMs?: number;
  duration?: string;
  className?: string;
}

function StaggeredList({
  children,
  staggerMs = 60,
  duration = '200ms',
  className,
}: StaggeredListProps) {
  return (
    <div className={className}>
      {children.map((child, i) => (
        <div
          key={i}
          style={{
            animation: `fadeSlideIn ${duration} var(--ease-out) ${i * staggerMs}ms both`,
          }}
        >
          {child}
        </div>
      ))}
    </div>
  );
}
```

**Usage:**
```tsx
<StaggeredList staggerMs={60}>
  {users.map(user => (
    <UserCard key={user.id} user={user} />
  ))}
</StaggeredList>
```

**Rules:**
- Stagger: `50–80ms` between items. Default `60ms`.
- Max items to stagger: ~10. Beyond that, render the rest at the same delay as item 10 to avoid slow perceived load.
- Duration per item: `200ms` with `--ease-out`

**Capped stagger for long lists:**
```tsx
const MAX_STAGGER_ITEMS = 10;

function StaggeredList({ children, staggerMs = 60 }: StaggeredListProps) {
  return (
    <div>
      {children.map((child, i) => (
        <div
          key={i}
          style={{
            animation: `fadeSlideIn 200ms var(--ease-out) ${Math.min(i, MAX_STAGGER_ITEMS) * staggerMs}ms both`,
          }}
        >
          {child}
        </div>
      ))}
    </div>
  );
}
```

