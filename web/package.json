{
  "name": "t2a-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock:graph:generate": "node ./scripts/generate-graph-mock.mjs",
    "mock:graph:100k": "node ./scripts/generate-graph-mock.mjs --node-count=100000 --output=public/mock-data/graphs/task-graph-100k.json",
    "mock:graph:200k": "node ./scripts/generate-graph-mock.mjs --node-count=200000 --output=public/mock-data/graphs/task-graph-200k.json",
    "mock:graph:use": "node ./scripts/use-graph-mock.mjs",
    "mock:graph:use:100k": "node ./scripts/use-graph-mock.mjs --size=100k",
    "mock:graph:use:200k": "node ./scripts/use-graph-mock.mjs --size=200k",
    "mock:graph:use:500k": "node ./scripts/use-graph-mock.mjs --size=500k"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/suggestion": "^3.21.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
