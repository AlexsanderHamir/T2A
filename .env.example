# Copy to `.env` in the repo root.
#
# Required — Postgres connection for taskapi.
# Native dev: localhost is fine.
# Docker dev: use host.docker.internal if Postgres runs on your machine — see docs/docker.md.
DATABASE_URL=postgres://user:pass@localhost:5432/hamix?sslmode=disable

#
# Optional — logging (defaults: ./logs, info level, JSON log files enabled)
# taskapi writes to ./logs under the repo (bind-mounted).
# HAMIX_LOG_LEVEL=debug
# HAMIX_DISABLE_LOGGING=1
