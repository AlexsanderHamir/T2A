# Copy to `.env` in the repo root (gitignored). taskapi loads it via `-env` (default: repo-root `.env`).
# Do not commit real credentials.
#
# Optional: directory for taskapi JSON log files (override with `taskapi -logdir`). Default is ./logs under cwd.
# T2A_LOG_DIR=
# Optional: minimum JSON log level (default info). Use debug for full trace volume locally. Override with `taskapi -loglevel`.
# T2A_LOG_LEVEL=debug
# Optional: no JSON log file; only errors to stderr (1|true|yes|on). Same as `taskapi -disable-logging`.
# T2A_DISABLE_LOGGING=1
# Optional: GORM slow-SQL warning threshold in milliseconds (default 200). Use 0 to disable slow-SQL Warn lines.
# T2A_GORM_SLOW_QUERY_MS=500
# Optional: per-IP HTTP requests per minute (default 120). Set to 0 to disable rate limiting.
# T2A_RATE_LIMIT_PER_MIN=300
# Optional: idempotency cache TTL for Idempotency-Key on POST/PATCH/DELETE (Go duration; default 24h). Set to 0 to disable.
# T2A_IDEMPOTENCY_TTL=24h

# Required for Postgres-backed taskapi (see README / docs/DESIGN.md).
DATABASE_URL=postgres://user:pass@localhost:5432/t2a?sslmode=disable

# Optional: absolute path to the workspace repo for GET /repo/* and @ file mentions in prompts.
# REPO_ROOT=

# Dev-only: synthetic SSE via rotating AppendTaskEvent (all EventType values, see docs/DESIGN.md). Never enable in prod without intent.
# T2A_SSE_TEST=1
# T2A_SSE_TEST_INTERVAL=3s
# T2A_SSE_TEST_EVENTS_PER_TICK=5
# T2A_SSE_TEST_SYNC_ROW=1
# T2A_SSE_TEST_USER_RESPONSE=1
# T2A_SSE_TEST_LIFECYCLE=1
# T2A_SSE_TEST_LIFECYCLE_EVERY=5

# Non-default API port when using scripts/dev.* — set both so Vite proxies to the right origin.
# DEV_TASKAPI_PORT=8081
# (in web/) VITE_TASKAPI_ORIGIN=http://127.0.0.1:8081
